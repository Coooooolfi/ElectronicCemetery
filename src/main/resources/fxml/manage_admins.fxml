<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.electroniccemetery.controller.ManageAdminsController"
            prefWidth="800" prefHeight="700" maxWidth="800" maxHeight="700">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Button text="Назад" onAction="#onBackClick" fx:id="backBtn"/>
            <Label text="Управление администраторами" styleClass="title"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" alignment="TOP_CENTER">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <TitledPane text="Создать администратора" expanded="false">
                <GridPane hgap="10" vgap="10" alignment="CENTER">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <Label text="Фамилия:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="lastNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Имя:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="firstNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Отчество:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="othestvoField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <Label text="Логин:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="loginField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    <Label text="Пароль:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="passwordField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <Label text="Кладбище:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cemeteryCombo" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="200"/>
                    <Button text="Создать" onAction="#onCreateAdminClick" GridPane.rowIndex="6" GridPane.columnSpan="2"/>
                </GridPane>
            </TitledPane>

            <TableView fx:id="adminsTable" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colLastName" text="Фамилия" prefWidth="120"/>
                    <TableColumn fx:id="colFirstName" text="Имя" prefWidth="120"/>
                    <TableColumn fx:id="colLogin" text="Логин" prefWidth="100"/>
                    <TableColumn fx:id="colCemetery" text="Кладбище" prefWidth="200"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Назначить на кладбище" onAction="#onAssignCemeteryClick"/>
                <Button text="Удалить" onAction="#onDeleteAdminClick"/>
            </HBox>

            <Label fx:id="statusLabel" textFill="red"/>
        </VBox>
    </center>
</BorderPane>