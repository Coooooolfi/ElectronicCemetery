<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.electroniccemetery.controller.SuperAdminController"
            prefWidth="800" prefHeight="700" maxWidth="800" maxHeight="700">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Button text="Выход" onAction="#onLogoutClick" fx:id="logoutBtn"/>
            <Label text="Панель супер-администратора" styleClass="title"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" alignment="CENTER">
            <Label text="Выберите действие:" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Button text="Управление администраторами" onAction="#onManageAdminsClick" prefWidth="250"/>
            <Button text="Управление кладбищами" onAction="#onManageCemeteriesClick" prefWidth="250"/>
            <Button text="Управление секторами" onAction="#onManageSectionsClick" prefWidth="250"/>
            <Button text="Управление участками" onAction="#onManagePlotsClick" prefWidth="250"/>

            <Label fx:id="statusLabel" textFill="red"/>
        </VBox>
    </center>
</BorderPane>